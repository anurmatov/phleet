# Fleet — Environment Variables Example
# Copy this file to .env and fill in your values.
# setup.sh creates .env at ./fleet/.env (not the repo root) — a gitignored
# subdir under the repo root that holds all runtime state.
# Never commit any copy of .env to version control.
#
# Note: FLEET_BASE_DIR is set automatically by setup.sh to ./fleet under the
# repo root. You don't need to configure it manually.

# ── CTO agent ─────────────────────────────────────────────────────────────────
# Short name of your co-cto agent (created interactively via ./setup.sh).
# Seed-shipped workflow definitions reference this via {{config.CtoAgent}} so
# they target your agent without hardcoding a name. Also used as the escalation
# target for workflow failure notifications.
FLEET_CTO_AGENT=

# Optional: Telegram group chat ID for fleet conversation visibility.
# Create a Telegram group, add every fleet bot (notifier + CTO) as members,
# then forward any message from the group to @userinfobot — it replies with
# the group's negative integer ID. Agents use this group to post status
# updates, workflow notifications, and cross-agent coordination messages.
# Leave blank to disable group routing (bots only respond to DMs) —
# docker-compose defaults it to 0 when unset.
FLEET_GROUP_CHAT_ID=

# ── Database ──────────────────────────────────────────────────────────────────
FLEET_MYSQL_ROOT_PASSWORD=changeme
FLEET_MYSQL_PASSWORD=fleetpass

# ── Telegram bot tokens ───────────────────────────────────────────────────────
# Create bots via @BotFather on Telegram. You need two bots:
# TELEGRAM_NOTIFIER_BOT_TOKEN — shared bot used by fleet-bridge and worker agents
#                               (developer, etc.) for DMs and group-chat relay
# TELEGRAM_CTO_BOT_TOKEN      — dedicated bot for the CTO agent's DMs with you
#                               (can reuse the same token if running only one bot)
TELEGRAM_NOTIFIER_BOT_TOKEN=654321:XYZ-GHI5678jkLmn-abc90W3w4x456ew22
TELEGRAM_CTO_BOT_TOKEN=

# Your Telegram numeric user ID — every agent you provision gets this ID added to
# its allowedTelegramUsers automatically so you can DM it immediately.
# To find your ID: send any message to @userinfobot on Telegram.
TELEGRAM_USER_ID=

# ── GitHub App ────────────────────────────────────────────────────────────────
# Create a GitHub App at github.com/settings/apps.
# Grant it repo read/write access and install it on the target org/account.
# GITHUB_APP_PEM: base64-encoded private key — run: base64 -w0 your-app.pem
GITHUB_APP_ID=123456
GITHUB_APP_PEM=base64-encoded-private-key-here

# ── Orchestrator auth ─────────────────────────────────────────────────────────
# Protects mutating REST endpoints on the orchestrator (POST/PUT/DELETE).
# Generate a random secret, e.g.: openssl rand -hex 32
ORCHESTRATOR_AUTH_TOKEN=your-secret-token-here

# ── MinIO (S3-compatible file sharing between agents) ─────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ── Fleet Memory embedding ────────────────────────────────────────────────────
# Embedding backend for fleet-memory. Options: onnx (default) or ollama.
# onnx runs inside the container with zero external deps.
# ollama requires ollama running on the host with a pulled model.
FLEET_MEMORY_EMBEDDING_PROVIDER=onnx
FLEET_MEMORY_EMBEDDING_DIMENSIONS=384
# Only needed when FLEET_MEMORY_EMBEDDING_PROVIDER=ollama:
# FLEET_MEMORY_OLLAMA_URL=http://host.docker.internal:11434
# FLEET_MEMORY_OLLAMA_MODEL=nomic-embed-text

# ── Auth token refresh (OAuth client IDs) ────────────────────────────────────
# Used by AuthTokenRefreshWorkflow to rotate Claude/Codex access tokens from
# their refresh tokens. These are per-application constants — same for every
# user of the Claude/Codex CLIs — and identify the CLI application, not your
# account. They are not secrets, so they ship with known defaults; override
# only if Anthropic/OpenAI rotate them.
AUTHTOKENREFRESH__CLAUDECLIENTID=9d1c250a-e61b-44d9-88ed-5944d1962f5e
AUTHTOKENREFRESH__CODEXCLIENTID=app_EMoamEEZ73f0CkXaXp7hrann
