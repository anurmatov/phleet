      "VocabPath": "./models/all-MiniLM-L6-v2-vocab.txt"
    },
    "Ollama": {
      "Url": "http://localhost:11434",
      "Model": "nomic-embed-text"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
