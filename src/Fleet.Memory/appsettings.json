{
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:3100"
      }
    }
  },
  "Storage": {
    "Path": "/data/memories"
  },
  "Qdrant": {
    "Url": "http://localhost:6334",
    "Collection": "fleet_memories"
  },
  "Embedding": {
