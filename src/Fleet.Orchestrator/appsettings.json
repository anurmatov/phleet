{
  "Docker": {
    "SocketPath": "/var/run/docker.sock"
  },
  "ConnectionStrings": {
    "OrchestratorDb": ""
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:3600"
      }
    }
  },
  "RabbitMq": {
    "Host": "",
    "Exchange": "fleet.orchestrator"
  },
  "Temporal": {
    "Address": "",
    "Namespaces": [ "fleet" ],
    "PollIntervalSeconds": 15
  },
  "Orchestrator": {
    "AuthToken": ""
  },
  "Provisioning": {
    "EnvFilePath": "/app/deploy/.env",
    "DefaultNetwork": "fleet-net",
    "AgentImage": "fleet:agent"
  },
  "FleetMemory": {
    "Url": "http://fleet-memory:3100",
    "McpUrl": "http://fleet-memory:3100/mcp"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
